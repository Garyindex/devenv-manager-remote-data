{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/devenv-manager/environment-tools.schema.json",
  "title": "DevEnv Manager environment tools",
  "type": "object",
  "required": ["schemaVersion", "tools", "suites"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/$defs/tool" }
    },
    "suites": {
      "type": "array",
      "items": { "$ref": "#/$defs/suite" }
    }
  },
  "$defs": {
    "tool": {
      "type": "object",
      "required": ["id", "name", "commands", "wingetId", "required", "category", "needsAdmin", "notes"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/command" }
        },
        "wingetId": { "type": "string" },
        "required": { "type": "boolean" },
        "category": { "type": "string", "minLength": 1 },
        "needsAdmin": { "type": "boolean" },
        "notes": { "type": "string" },
        "versionOptions": {
          "type": "array",
          "items": { "$ref": "#/$defs/versionOption" }
        }
      }
    },
    "command": {
      "type": "object",
      "required": ["command", "versionArg"],
      "additionalProperties": true,
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "versionArg": { "type": "string", "minLength": 1 }
      }
    },
    "versionOption": {
      "type": "object",
      "required": ["id", "label", "wingetId"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "wingetId": { "type": "string", "minLength": 1 }
      }
    },
    "suite": {
      "type": "object",
      "required": ["id", "name", "description", "toolIds"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "toolIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}

